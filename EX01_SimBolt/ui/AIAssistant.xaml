<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="320">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>  <!-- Header -->
      <RowDefinition Height="Auto"/>  <!-- First-run config -->
      <RowDefinition Height="*"/>     <!-- Chat -->
      <RowDefinition Height="Auto"/>  <!-- Prompt -->
    </Grid.RowDefinitions>

    <!-- Header -->
    <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,8">
      <TextBlock Text="AI Assistant" FontSize="16" FontWeight="SemiBold"/>
      <TextBlock Name="StatusText" Text="Idle" Margin="10,2,0,0" Foreground="#666"/>
    </DockPanel>

    <!-- First-run configuration panel -->
    <Border Grid.Row="1"
            Name="ConfigPanel"
            BorderBrush="#D9D9D9"
            BorderThickness="1"
            CornerRadius="4"
            Padding="10"
            Margin="0,0,0,8"
            Background="#FAFAFA">
      <StackPanel>
        <TextBlock FontWeight="SemiBold" Text="首次使用：请配置大模型连接" Margin="0,0,0,6"/>
        <TextBlock Foreground="#444" TextWrapping="Wrap" Margin="0,0,0,10">
          该配置将保存在本机 config.json 中。API Key 不会输出到日志。配置完成后即可开始聊天。
        </TextBlock>

        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="URL" VerticalAlignment="Center" Margin="0,0,8,6"/>
          <TextBox   Grid.Row="0" Grid.Column="1" Name="CfgBaseUrl" Margin="0,0,0,6"
                     Text="http://aic.byd.com/model-gateway/v1"/>

          <TextBlock Grid.Row="1" Grid.Column="0" Text="Model" VerticalAlignment="Center" Margin="0,0,8,6"/>
          <TextBox   Grid.Row="1" Grid.Column="1" Name="CfgModel" Margin="0,0,0,6"
                     Text="glm-4-7-fp8"/>

          <TextBlock Grid.Row="2" Grid.Column="0" Text="API Key" VerticalAlignment="Center" Margin="0,0,8,6"/>
          <PasswordBox Grid.Row="2" Grid.Column="1" Name="CfgApiKey" Margin="0,0,0,6"/>

          <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="SaveConfigButton" Content="Save" MinWidth="80" Padding="12,6" Margin="0,0,8,0"/>
            <Button Name="HideConfigButton" Content="Hide" MinWidth="80" Padding="12,6"/>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Chat log -->
    <Border Grid.Row="2"
            BorderBrush="#D9D9D9"
            BorderThickness="1"
            CornerRadius="4"
            Padding="6"
            Margin="0,0,0,8">
      <TextBox Name="ChatLog"
               IsReadOnly="True"
               TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto"
               BorderThickness="0"
               Background="Transparent"/>
    </Border>

    <!-- Prompt -->
    <Grid Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <TextBox Name="PromptBox"
               Grid.Column="0"
               MinHeight="64"
               AcceptsReturn="True"
               TextWrapping="Wrap"
               VerticalScrollBarVisibility="Auto"
               Margin="0,0,8,0"/>

      <Button Name="SendButton"
              Grid.Column="1"
              MinWidth="80"
              Padding="12,8"
              Content="Send"/>
    </Grid>
  </Grid>
</UserControl>
